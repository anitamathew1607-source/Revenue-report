-- Base revenue query
SELECT
  order_id,
  customer_id,
  revenue
FROM orders
WHERE status = 'completed'
  AND order_date >= '2024-01-01'
  AND revenue > 0

SELECT
  DATE_TRUNC('month', order_date) AS month,
  COUNT(order_id)                 AS total_orders,
  SUM(revenue)                    AS total_revenue
FROM orders
WHERE status = 'completed'
  AND order_date >= '2024-01-01'
GROUP BY 1
ORDER BY 1
